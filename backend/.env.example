# Backend configuration
MONGO_URI=mongodb://127.0.0.1:27017/beehive
PORT=3001

# Simulator (Hive_02..Hive_05)
SIM_INTERVAL=10000
OFFLINE_THRESHOLD=60000

# Alerts
ALERT_COOLDOWN_MS=300000

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Seed admin on startup (dev/demo)
AUTO_SEED_ADMIN=true
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin1234

# Data retention
RETENTION_ENABLED=true
RETENTION_DAYS=90
RETENTION_JOB_INTERVAL_MS=21600000

# Optional LLM chatbot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
